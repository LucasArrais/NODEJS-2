generator client {
  provider = "prisma-client"
  output   = "../src/@types/prisma"
}

datasource db {
  provider = "postgresql"
}

enum USER_ROLE {
  ADMIN
  DEFAULT
}

model User {
  id        Int        @id @default(autoincrement())
  public_id String     @unique @map("public_id") @default(uuid())
  name      String
  email     String     @unique
  password  String
  photo     String?
  role      USER_ROLE  @default(DEFAULT)

  posts     Post[]
  comments  Comment[]
  likes     Like[]
}

model Post {
  id         Int       @id @default(autoincrement())
  public_id  String    @unique @map("public_id") @default(uuid())
  titulo     String
  conteudo   String
  created_at DateTime  @default(now())

  usuarioId  Int
  usuario    User      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  comments   Comment[]
  likes      Like[]
}

model Comment {
  id         Int       @id @default(autoincrement())
  public_id  String    @unique @map("public_id") @default(uuid())
  conteudo   String
  created_at DateTime  @default(now())

  usuarioId  Int
  usuario    User      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  postId     Int
  post       Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  likes      Like[]
}

model Like {
  id         Int       @id @default(autoincrement())
  public_id  String    @unique @map("public_id") @default(uuid())
  created_at DateTime  @default(now())

  usuarioId  Int
  usuario    User      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  postId     Int?
  post       Post?     @relation(fields: [postId], references: [id], onDelete: Cascade)

  commentId  Int?
  comment    Comment?  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, postId])
  @@unique([usuarioId, commentId])
}